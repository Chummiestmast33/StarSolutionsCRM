<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.starsolutions.starsolutionscrm.controller.rrhh.EmpleadoFormController"
      prefWidth="360.0" spacing="14"
      style="-fx-padding: 24;">

    <!-- Título -->
    <Label text="Datos del Empleado"
           style="-fx-font-size: 15px; -fx-font-weight: bold;"/>

    <!-- Nombre -->
    <Label text="Nombre completo"/>
    <TextField fx:id="txtNombre"
               promptText="Ej. Juan García"/>

    <!-- Contraseña (solo en modo nuevo) -->
    <Label text="Contraseña"/>
    <TextField fx:id="txtContrasena"
               promptText="Contraseña inicial"/>

    <!-- Tipo de empleado (solo en modo nuevo) -->
    <Label text="Tipo de empleado"/>
    <ComboBox fx:id="cmbTipo"
              promptText="Selecciona un tipo"
              maxWidth="Infinity"/>

    <!-- Botones -->
    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
        <Button text="Cancelar" onAction="#onCancelar"/>
        <Button text="Guardar"  onAction="#onGuardar" defaultButton="true"
                style="-fx-font-weight: bold;"/>
    </HBox>

</VBox>