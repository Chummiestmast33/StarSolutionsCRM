<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.starsolutions.starsolutionscrm.controller.rrhh.NominaListaController"
            prefHeight="520.0" prefWidth="820.0">

    <!-- ===== BARRA SUPERIOR ===== -->
    <top>
        <VBox style="-fx-padding: 12 16 12 16; -fx-background-color: #f4f4f4;
                     -fx-border-color: #cccccc; -fx-border-width: 0 0 1 0;" spacing="10">

            <Label text="Nómina"
                   style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

            <!-- Filtros -->
            <HBox spacing="10" alignment="CENTER_LEFT">

                <!-- Filtro por empleado -->
                <Label text="Núm. empleado:"/>
                <TextField fx:id="txtFiltroEmpleado"
                           promptText="Ej. 1001"
                           prefWidth="100"/>
                <Button text="Buscar empleado" onAction="#onFiltrarPorEmpleado"/>

                <Separator orientation="VERTICAL"/>

                <!-- Filtro por período -->
                <Label text="Período:"/>
                <DatePicker fx:id="dpFiltroMes" prefWidth="150"/>
                <Button text="Buscar período" onAction="#onFiltrarPorPeriodo"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="Refrescar" onAction="#onRefrescar"/>

            </HBox>
        </VBox>
    </top>

    <!-- ===== TABLA ===== -->
    <center>
        <TableView fx:id="tablaNomina" style="-fx-padding: 12;">
            <columns>
                <TableColumn fx:id="colId"          text="ID Nómina"    prefWidth="90"/>
                <TableColumn fx:id="colEmpleado"    text="Núm. Empleado" prefWidth="120"/>
                <TableColumn fx:id="colSalarioBase" text="Salario Base"  prefWidth="130"/>
                <TableColumn fx:id="colDeducciones" text="Deducciones"   prefWidth="120"/>
                <TableColumn fx:id="colNeto"        text="Neto"          prefWidth="120"/>
                <TableColumn fx:id="colPeriodo"     text="Período"       prefWidth="120"/>
            </columns>
            <placeholder>
                <Label text="No hay registros de nómina para mostrar."/>
            </placeholder>
        </TableView>
    </center>

</BorderPane>