<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.starsolutions.starsolutionscrm.controller.compras.OrdenCompraListaController"
            prefHeight="600.0" prefWidth="1000.0">

    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 14; -fx-background-color: #f7f7f7;">
            <Label text="Órdenes de Compra" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Nueva" onAction="#onNueva"/>
            <Button text="Recepción" onAction="#onRecepcion"/>
            <Button text="Pagado" onAction="#onPagado"/>
            <Button text="Refrescar" onAction="#onRefrescar"/>
        </HBox>
    </top>

    <center>
        <TableView fx:id="tablaOrdenes">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="70"/>
                <TableColumn fx:id="colProveedor" text="Proveedor" prefWidth="110"/>
                <TableColumn fx:id="colEmpleado" text="Empleado" prefWidth="110"/>
                <TableColumn fx:id="colFecha" text="Fecha" prefWidth="220"/>
                <TableColumn fx:id="colEstado" text="Estado" prefWidth="140"/>
                <TableColumn fx:id="colTotal" text="Total" prefWidth="120"/>
            </columns>
            <placeholder>
                <Label text="No hay órdenes registradas"/>
            </placeholder>
        </TableView>
    </center>

</BorderPane>
