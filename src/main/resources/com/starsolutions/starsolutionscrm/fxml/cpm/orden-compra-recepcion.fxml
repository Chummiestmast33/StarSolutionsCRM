<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.starsolutions.starsolutionscrm.controller.compras.OrdenCompraRecepcionController"
            prefHeight="650.0" prefWidth="1100.0">

    <top>
        <VBox spacing="10" style="-fx-padding: 14; -fx-background-color: #f7f7f7;">
            <Label fx:id="lblOrden" text="Orden de compra" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Label fx:id="lblEstado" text="Estado" style="-fx-padding: 6 10 6 10; -fx-background-color: #607d8b; -fx-text-fill: white; -fx-font-weight: bold;"/>

            <GridPane hgap="10" vgap="8">
                <columnConstraints>
                    <ColumnConstraints minWidth="120"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                    <ColumnConstraints minWidth="120"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Cantidad recibida" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="txtCantidadRecibida" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Referencia" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                <TextField fx:id="txtReferencia" GridPane.rowIndex="0" GridPane.columnIndex="3"/>
            </GridPane>

            <HBox spacing="10">
                <Button text="Registrar Recepción" onAction="#onRegistrarRecepcion"/>
                <Button text="Marcar Pagada" onAction="#onMarcarPagada"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Cerrar" onAction="#onCerrar"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="tablaDetalle">
            <columns>
                <TableColumn fx:id="colProducto" text="Producto" prefWidth="120"/>
                <TableColumn fx:id="colPedida" text="Pedida" prefWidth="100"/>
                <TableColumn fx:id="colRecibida" text="Recibida" prefWidth="100"/>
                <TableColumn fx:id="colPendiente" text="Pendiente" prefWidth="100"/>
                <TableColumn fx:id="colPrecio" text="Precio" prefWidth="120"/>
            </columns>
            <placeholder>
                <Label text="Selecciona una orden para cargar sus líneas"/>
            </placeholder>
        </TableView>
    </center>

</BorderPane>
