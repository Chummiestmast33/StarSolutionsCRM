<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!-- Vista del historial general de ventas -->
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.starsolutions.starsolutionscrm.controller.ventas.VentaHistorialController">

    <top>
    <VBox spacing="8">
        <padding><Insets top="10" right="10" bottom="6" left="10"/></padding>
        <Label text="Historial de Ventas" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <ComboBox fx:id="cmbCliente" promptText="Seleccionar cliente (o buscar...)" prefWidth="200" editable="true"/>
            <DatePicker fx:id="dpFechaInicio" promptText="Desde"/>
            <DatePicker fx:id="dpFechaFin" promptText="Hasta"/>
            <ComboBox fx:id="cbEstatus" promptText="Estatus" prefWidth="130"/>
            <Button text="Filtrar"    onAction="#onFiltrar"/>
            <Button text="Limpiar"   onAction="#onLimpiarFiltros"/>
            <Button text="Actualizar" onAction="#cargarHistorial"/>
        </HBox>
    </VBox>
</top>

    <center>
        <TableView fx:id="tablaHistorial">
            <columns>
                <TableColumn fx:id="colIdVenta" text="ID Venta" prefWidth="80"/>
                <TableColumn fx:id="colFecha" text="Fecha" prefWidth="120"/>
                <TableColumn fx:id="colEstatus" text="Estatus" prefWidth="120"/>
                <TableColumn fx:id="colCondicion" text="Tipo de Pago" prefWidth="120"/>
                <TableColumn fx:id="colTotal" text="Total ($)" prefWidth="150"/>
            </columns>
        </TableView>
    </center>
</BorderPane>