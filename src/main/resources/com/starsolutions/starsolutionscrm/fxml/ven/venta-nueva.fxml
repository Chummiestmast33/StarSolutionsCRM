<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.starsolutions.starsolutionscrm.controller.ventas.VentaNuevaController"
            style="-fx-background-color: transparent;">

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <!-- Center: Main POS Area (Cart / Ticket) -->
    <center>
        <VBox spacing="16" style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4);">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <BorderPane.margin>
                <Insets right="16"/>
            </BorderPane.margin>

            <!-- Header and Client/Product Input -->
            <HBox spacing="20" alignment="CENTER_LEFT">
                <FontIcon iconLiteral="fltfal-cart-24" iconSize="32" iconColor="#005FB8"/>
                <Label text="Punto de Venta" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI Variable Display', 'Segoe UI', sans-serif;"/>
            </HBox>

            <HBox spacing="16" alignment="BOTTOM_LEFT">
                <!-- Cliente Input -->
                <VBox spacing="4" HBox.hgrow="SOMETIMES">
                    <Label text="Cliente" style="-fx-text-fill: #666666; -fx-font-weight: bold;"/>
                    <ComboBox fx:id="cmbCliente" maxWidth="Infinity" promptText="Buscar cliente por ID, nombre o RFC..." editable="true"/>
                </VBox>

                <!-- Tipo de Pago -->
                <VBox spacing="4">
                    <Label text="Condición Pago" style="-fx-text-fill: #666666; -fx-font-weight: bold;"/>
                    <ComboBox fx:id="cmbTipoPago" prefWidth="150" promptText="Cobro a..."/>
                </VBox>
            </HBox>

            <Separator/>

            <!-- Product Search input bar -->
            <HBox spacing="10" alignment="BOTTOM_LEFT">
                <VBox spacing="4">
                    <Label text="Producto" style="-fx-text-fill: #666666; -fx-font-weight: bold;"/>
                    <ComboBox fx:id="cmbProducto" prefWidth="260" promptText="Buscar o seleccionar producto..."/>
                </VBox>
                <VBox spacing="4">
                    <Label text="Cantidad" style="-fx-text-fill: #666666; -fx-font-weight: bold;"/>
                    <ComboBox fx:id="cmbCantidad" prefWidth="80" promptText="1"/>
                </VBox>
                <Button text="Agregar al Ticket" onAction="#onAgregarProducto" prefHeight="32">
                    <graphic>
                        <FontIcon iconLiteral="fltfal-add-24"/>
                    </graphic>
                </Button>
            </HBox>

            <!-- Table of Items -->
            <TableView fx:id="tablaDetalles" VBox.vgrow="ALWAYS" styleClass="striped">
                <columns>
                    <TableColumn fx:id="colProducto"   text="Cod. Producto"  prefWidth="120"/>
                    <TableColumn fx:id="colCantidad"   text="Cant."          prefWidth="80"/>
                    <TableColumn fx:id="colPrecio"     text="Precio Unit."   prefWidth="120"/>
                    <TableColumn fx:id="colDescuento"  text="Desc. VIP"      prefWidth="120"/>
                    <TableColumn fx:id="colSubtotalLinea" text="Importe Total" prefWidth="150"/>
                </columns>
                <placeholder>
                    <VBox alignment="CENTER" spacing="10">
                        <FontIcon iconLiteral="fltfmz-reciept-24" iconSize="48" iconColor="#DDDDDD"/>
                        <Label text="El ticket está vacío." style="-fx-text-fill: #888888;"/>
                    </VBox>
                </placeholder>
            </TableView>

        </VBox>
    </center>

    <!-- Right: Summary Panel -->
    <right>
        <VBox spacing="20" prefWidth="340" style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4);">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <Label text="Resumen de Venta" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Separator/>

            <!-- Removing an item -->
            <VBox alignment="CENTER_RIGHT">
                <Button text="Eliminar producto seleccionado" onAction="#onQuitarProducto" styleClass="flat, danger">
                    <graphic>
                        <FontIcon iconLiteral="fltfal-delete-24" iconColor="#d13438"/>
                    </graphic>
                </Button>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Totals -->
            <VBox spacing="12" style="-fx-background-color: #F8F9FA; -fx-background-radius: 6; -fx-padding: 16;">
                <HBox>
                    <Label text="Subtotal:" style="-fx-font-size: 14px; -fx-text-fill: #666666;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblSubtotal" text="\$ 0.00" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                </HBox>

                <HBox>
                    <Label text="Descuentos Aplicados:" style="-fx-font-size: 14px; -fx-text-fill: #d13438;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblDescuentos" text="-\$ 0.00" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #d13438;"/>
                </HBox>

                <Separator/>

                <VBox alignment="CENTER_RIGHT" spacing="4">
                    <Label text="TOTAL A COBRAR" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #005FB8;"/>
                    <Label fx:id="lblTotal" text="\$ 0.00" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #005FB8;"/>
                </VBox>
            </VBox>

            <Button text="Registrar y Cobrar" onAction="#onCobrar" styleClass="accent" prefHeight="50" maxWidth="Infinity" style="-fx-font-size: 16px; -fx-font-weight: bold;">
                <graphic>
                    <FontIcon iconLiteral="fltfmz-payment-24" iconColor="white" iconSize="20"/>
                </graphic>
            </Button>
        </VBox>
    </right>

</BorderPane>