<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.starsolutions.starsolutionscrm.controller.inventario.StockAjusteController"
      prefWidth="420.0" spacing="12"
      style="-fx-padding: 24;">

    <Label text="Ajuste de Inventario" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="120"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="ID Producto" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="txtIdProducto" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Ubicación" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="txtUbicacion" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Tipo" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <ComboBox fx:id="cmbTipo" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Cantidad" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="txtCantidad" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Referencia" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="txtReferencia" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancelar" onAction="#onCancelar"/>
        <Button text="Guardar" onAction="#onGuardar" defaultButton="true"/>
    </HBox>

</VBox>
