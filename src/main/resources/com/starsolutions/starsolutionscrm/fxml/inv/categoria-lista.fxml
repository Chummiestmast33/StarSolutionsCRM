<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.starsolutions.starsolutionscrm.controller.inventario.CategoriaListaController">
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
            <Label text="Categorías de Producto" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Nueva Categoría" onAction="#onNueva"/>
        </HBox>
    </top>
    <center>
        <TableView fx:id="tablaCategoria">
            <columns>
                <TableColumn fx:id="colId"          text="ID"          prefWidth="60"/>
                <TableColumn fx:id="colNombre"      text="Nombre"      prefWidth="200"/>
                <TableColumn fx:id="colDescripcion" text="Descripción" prefWidth="300"/>
                <TableColumn fx:id="colActivo"      text="Activo"      prefWidth="80"/>
            </columns>
        </TableView>
    </center>
    <bottom>
        <VBox spacing="8">
            <padding><Insets top="8" right="10" bottom="10" left="10"/></padding>
            <HBox spacing="10">
                <TextField fx:id="txtNombre"      promptText="Nombre"      prefWidth="200"/>
                <TextField fx:id="txtDescripcion" promptText="Descripción" prefWidth="300"/>
                <Button text="Guardar"     onAction="#onGuardar"/>
                <Button text="Editar sel." onAction="#onEditar"/>
                <Button text="Desactivar"  onAction="#onDesactivar"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>