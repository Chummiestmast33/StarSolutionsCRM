<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.starsolutions.starsolutionscrm.controller.inventario.ProductoListaController"
            prefHeight="600.0" prefWidth="1000.0"
            stylesheets="@../../css/styles.css">

    <top>
        <VBox spacing="10" style="-fx-padding: 14; -fx-background-color: #f7f7f7;">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Productos" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="txtBuscar" promptText="Buscar por nombre" prefWidth="260"/>
                <Button text="Buscar" onAction="#onBuscar"/>
                <Button text="Refrescar" onAction="#onRefrescar"/>
                <Button text="Nuevo" onAction="#onNuevo"/>
                <Button text="Editar" onAction="#onEditar"/>
                <Button text="Desactivar" onAction="#onDesactivar"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="tablaProductos">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="70"/>
                <TableColumn fx:id="colNombre" text="Nombre" prefWidth="220"/>
                <TableColumn fx:id="colDescripcion" text="Descripción" prefWidth="280"/>
                <TableColumn fx:id="colPrecio" text="Precio" prefWidth="120"/>
                <TableColumn fx:id="colCategoria" text="Categoría" prefWidth="100"/>
                <TableColumn fx:id="colActivo" text="Activo" prefWidth="80"/>
            </columns>
            <placeholder>
                <Label text="No hay productos para mostrar"/>
            </placeholder>
        </TableView>
    </center>

</BorderPane>
