<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.starsolutions.starsolutionscrm.controller.compras.ProveedorFormController"
      prefWidth="380.0" spacing="14"
      style="-fx-padding: 24;">

    <!-- Titulo -->
    <Label text="Datos del Proveedor"
           style="-fx-font-size: 15px; -fx-font-weight: bold;"/>

    <!-- Campos de texto -->
    <Label text="Nombre de la Empresa"/>
    <TextField fx:id="txtNombre" promptText="Ej. Telas y Mas SA"/>

    <Label text="RFC (Opcional)"/>
    <TextField fx:id="txtRfc" promptText="13 caracteres maximo"/>

    <Label text="Direccion"/>
    <TextField fx:id="txtDireccion" promptText="Calle, numero, colonia"/>

    <!-- Contenedor de botones -->
    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
        <Button text="Cancelar" onAction="#onCancelar"/>
        <Button text="Guardar"  onAction="#onGuardar" defaultButton="true"
                style="-fx-font-weight: bold; -fx-background-color: #2196F3; -fx-text-fill: white;"/>
    </HBox>

</VBox>