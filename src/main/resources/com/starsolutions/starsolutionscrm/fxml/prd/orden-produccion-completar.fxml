<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.starsolutions.starsolutionscrm.controller.produccion.OrdenProduccionCompletarController"
      prefWidth="380.0" spacing="14"
      style="-fx-padding: 24;">

    <!-- Título -->
    <Label text="Completar Orden de Producción"
           style="-fx-font-size: 15px; -fx-font-weight: bold;"/>

    <!-- Datos de la orden (solo lectura, los llena el controller) -->
    <VBox spacing="6"
          style="-fx-background-color: #f4f4f4; -fx-padding: 12;
                 -fx-border-color: #cccccc; -fx-border-radius: 4;">

        <Label text="Datos de la orden:" style="-fx-font-weight: bold;"/>
        <Label fx:id="lblIdOrden"     text="Orden #—"/>
        <Label fx:id="lblProducto"    text="Producto ID: —"/>
        <Label fx:id="lblPlanificado" text="Cantidad planificada: —"/>

    </VBox>

    <!-- Cantidad producida -->
    <Label text="Cantidad producida"/>
    <TextField fx:id="txtCantidadProducida"
               promptText="Ej. 95"/>

    <!-- Botones -->
    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
        <Button text="Cancelar"  onAction="#onCancelar"/>
        <Button text="Completar" onAction="#onCompletar" defaultButton="true"
                style="-fx-font-weight: bold;"/>
    </HBox>

</VBox>