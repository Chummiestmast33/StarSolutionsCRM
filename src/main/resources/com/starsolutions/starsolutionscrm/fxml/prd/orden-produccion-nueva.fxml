<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.starsolutions.starsolutionscrm.controller.produccion.OrdenProduccionNuevaController"
      prefWidth="380.0" spacing="14"
      style="-fx-padding: 24;">

    <!-- Título -->
    <Label text="Nueva Orden de Producción"
           style="-fx-font-size: 15px; -fx-font-weight: bold;"/>

    <!-- ID Producto -->
    <Label text="ID del producto final"/>
    <TextField fx:id="txtIdProducto"
               promptText="Ej. 3"/>

    <!-- Cantidad planificada -->
    <Label text="Cantidad planificada"/>
    <TextField fx:id="txtCantidadPlanificada"
               promptText="Ej. 100"/>

    <!-- Fecha estimada de fin (opcional) -->
    <Label text="Fecha estimada de fin  (opcional)"/>
    <DatePicker fx:id="dpFechaEstimada"
                maxWidth="Infinity"/>

    <!-- Botones -->
    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
        <Button text="Cancelar" onAction="#onCancelar"/>
        <Button text="Guardar"  onAction="#onGuardar" defaultButton="true"
                style="-fx-font-weight: bold;"/>
    </HBox>

</VBox>