<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.starsolutions.starsolutionscrm.controller.base.MainController"
            prefHeight="720.0" prefWidth="1280.0"
            style="-fx-background-color: #F8F8F8;">

    <!-- Barra superior -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-background-color: #ffffff; -fx-border-color: #E5E5E5; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets top="2" right="20" bottom="2" left="20"/>
            </padding>

            <Button fx:id="btnMenuToggle" onAction="#onToggleMenu" styleClass="flat">
                <graphic>
                    <FontIcon iconLiteral="fltfmz-navigation-20" iconSize="20"/>
                </graphic>
            </Button>

            <ImageView fx:id="imgLogo" fitWidth="200" fitHeight="90" preserveRatio="true" smooth="true"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Area de Perfil del Usuario -->
            <HBox alignment="CENTER_RIGHT" spacing="10">
                <VBox alignment="CENTER_RIGHT">
                    <Label fx:id="lblBienvenida" text="Usuario" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                    <Label fx:id="lblRol" text="Rol" style="-fx-font-size: 11px; -fx-text-fill: #666666;"/>
                </VBox>
                <Button onAction="#onCerrarSesion" styleClass="flat, danger">
                    <graphic>
                        <FontIcon iconLiteral="fltfmz-sign-out-24" iconSize="20" iconColor="#d13438"/>
                    </graphic>
                </Button>
            </HBox>
        </HBox>
    </top>

    <!-- Menu lateral izquierdo -->
    <left>
        <VBox fx:id="sideMenu" spacing="4" style="-fx-background-color: #F3F3F3; -fx-border-color: #E5E5E5; -fx-border-width: 0 1 0 0; -fx-pref-width: 220;">
            <padding>
                <Insets top="16" right="8" bottom="16" left="8"/>
            </padding>

            <ScrollPane fitToWidth="true" vbarPolicy="AS_NEEDED" hbarPolicy="NEVER" style="-fx-background-color: transparent;">
                <VBox spacing="2" style="-fx-background-color: transparent;">

                    <!-- Menu items in a continuous list (no header labels) -->
                    <Button fx:id="btnEmpleados" text="Empleados" onAction="#onEmpleados" styleClass="flat" maxWidth="Infinity" alignment="BASELINE_LEFT">
                        <graphic><FontIcon iconLiteral="fltfmz-person-24" iconSize="18"/></graphic>
                    </Button>
                    <Button fx:id="btnNomina" text="Nómina" onAction="#onNomina" styleClass="flat" maxWidth="Infinity" alignment="BASELINE_LEFT">
                        <graphic><FontIcon iconLiteral="fltfmz-money-24" iconSize="18"/></graphic>
                    </Button>
                    <Button fx:id="btnAsistencia" text="Asistencia" onAction="#onAsistencia" styleClass="flat" maxWidth="Infinity" alignment="BASELINE_LEFT">
                        <graphic><FontIcon iconLiteral="fltfal-calendar-24" iconSize="18"/></graphic>
                    </Button>
                    <Button fx:id="btnIndicadores" text="Indicadores" onAction="#onIndicadores" styleClass="flat" maxWidth="Infinity" alignment="BASELINE_LEFT">
                        <graphic><FontIcon iconLiteral="fltfmz-ribbon-star-24" iconSize="18"/></graphic>
                    </Button>
                    <Button fx:id="btnProduccion" text="Producción" onAction="#onProduccion" styleClass="flat" maxWidth="Infinity" alignment="BASELINE_LEFT">
                        <graphic><FontIcon iconLiteral="fltfal-building-24" iconSize="18"/></graphic>
                    </Button>
                    <Button fx:id="btnProveedores" text="Proveedores" onAction="#onProveedores" styleClass="flat" maxWidth="Infinity" alignment="BASELINE_LEFT">
                        <graphic><FontIcon iconLiteral="fltfal-cube-24" iconSize="18"/></graphic>
                    </Button>
                    <Button fx:id="btnProductos" text="Productos" onAction="#onProductos" styleClass="flat" maxWidth="Infinity" alignment="BASELINE_LEFT">
                        <graphic><FontIcon iconLiteral="fltfal-grid-24" iconSize="18"/></graphic>
                    </Button>
                    <Button fx:id="btnCategorias" text="Categorías" onAction="#onCategorias" styleClass="flat" maxWidth="Infinity" alignment="BASELINE_LEFT">
                        <graphic><FontIcon iconLiteral="fltfmz-tag-24" iconSize="18"/></graphic>
                    </Button>
                    <Button fx:id="btnStock" text="Stock" onAction="#onStock" styleClass="flat" maxWidth="Infinity" alignment="BASELINE_LEFT">
                        <graphic><FontIcon iconLiteral="fltfal-book-coins-24" iconSize="18"/></graphic>
                    </Button>
                    <Button fx:id="btnAjusteStock" text="Ajuste Stock" onAction="#onAjusteStock" styleClass="flat" maxWidth="Infinity" alignment="BASELINE_LEFT">
                        <graphic><FontIcon iconLiteral="fltfmz-settings-24" iconSize="18"/></graphic>
                    </Button>
                    <Button fx:id="btnCompras" text="Compras" onAction="#onCompras" styleClass="flat" maxWidth="Infinity" alignment="BASELINE_LEFT">
                        <graphic><FontIcon iconLiteral="fltfmz-reciept-24" iconSize="18"/></graphic>
                    </Button>

                    <Separator />

                    <Button fx:id="btnClientes" text="Clientes" onAction="#onClientes" styleClass="flat" maxWidth="Infinity" alignment="BASELINE_LEFT">
                        <graphic><FontIcon iconLiteral="fltfmz-people-24" iconSize="18"/></graphic>
                    </Button>
                    <Button fx:id="btnClienteDescuento" text="Descuentos VIP" onAction="#onClienteDescuento" styleClass="flat" maxWidth="Infinity" alignment="BASELINE_LEFT">
                        <graphic><FontIcon iconLiteral="fltfmz-star-24" iconSize="18"/></graphic>
                    </Button>
                    <Button fx:id="btnVentas" text="Punto de Venta" onAction="#onVentas" styleClass="flat" maxWidth="Infinity" alignment="BASELINE_LEFT">
                        <graphic><FontIcon iconLiteral="fltfal-cart-24" iconSize="18"/></graphic>
                    </Button>
                    <Button fx:id="btnHistorial" text="Historial" onAction="#onHistorial" styleClass="flat" maxWidth="Infinity" alignment="BASELINE_LEFT">
                        <graphic><FontIcon iconLiteral="fltfal-history-24" iconSize="18"/></graphic>
                    </Button>
                    <Button fx:id="btnCobros" text="Cobros" onAction="#onCobros" styleClass="flat" maxWidth="Infinity" alignment="BASELINE_LEFT">
                        <graphic><FontIcon iconLiteral="fltfmz-payment-24" iconSize="18"/></graphic>
                    </Button>
                    <Button fx:id="btnDevoluciones" text="Devoluciones" onAction="#onDevoluciones" styleClass="flat" maxWidth="Infinity" alignment="BASELINE_LEFT">
                        <graphic><FontIcon iconLiteral="fltfal-arrow-hook-down-left-24" iconSize="18"/></graphic>
                    </Button>
                    <Button fx:id="btnPromociones" text="Promociones" onAction="#onPromociones" styleClass="flat" maxWidth="Infinity" alignment="BASELINE_LEFT">
                        <graphic><FontIcon iconLiteral="fltfmz-ticket-24" iconSize="18"/></graphic>
                    </Button>

                </VBox>
            </ScrollPane>
        </VBox>
    </left>

    <!-- Area central dinámica -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #F8F8F8;">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <VBox alignment="CENTER" spacing="12">
                <FontIcon iconLiteral="fltfal-home-24" iconSize="48" iconColor="#CCCCCC"/>
                <Label text="Selecciona un módulo del menú lateral para comenzar" style="-fx-font-size: 15px; -fx-text-fill: #888888;"/>
            </VBox>
        </StackPane>
    </center>

</BorderPane>