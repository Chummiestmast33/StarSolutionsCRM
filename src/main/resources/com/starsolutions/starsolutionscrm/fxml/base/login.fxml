<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.starsolutions.starsolutionscrm.controller.base.LoginController"
            prefHeight="400.0" prefWidth="600.0">

    <!-- Panel central centrado -->
    <VBox alignment="CENTER"
          spacing="16"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <ImageView fx:id="imgLogo"
                   fitWidth="240"
                   fitHeight="100"
                   preserveRatio="true"
                   smooth="true"/>

        <Label text="Iniciar Sesión"
               style="-fx-font-size: 14px; -fx-text-fill: #555555;"/>

        <!-- Formulario -->
        <VBox spacing="10" maxWidth="280">

            <Label text="Número de empleado"/>
            <TextField fx:id="txtNumero"
                       promptText="Ej. 1001"
                       maxWidth="280"/>

            <Label text="Contraseña"/>
            <PasswordField fx:id="txtContrasena"
                           promptText="Ingresa tu contraseña"
                           maxWidth="280"/>

            <!-- Mensaje de error (oculto por defecto) -->
            <Label fx:id="lblError"
                   text=""
                   visible="false"
                   wrapText="true"
                   maxWidth="280"
                   style="-fx-text-fill: red; -fx-font-size: 12px;"/>

            <!-- Botón de login -->
            <Button text="Entrar"
                    onAction="#onLogin"
                    maxWidth="280"
                    defaultButton="true"
                    style="-fx-font-size: 13px;"/>

        </VBox>

    </VBox>

</AnchorPane>
